.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  padding: 60rpx 30rpx 40rpx;
  border-radius: 0 0 30rpx 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #fff;
}

.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 24rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.quick-actions {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  margin-top: -20rpx;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.action-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.action-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.section {
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #409EFF;
}

.session-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.session-item:last-child {
  border-bottom: none;
}

.session-main {
  flex: 1;
}

.session-position {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.session-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.session-time {
  font-size: 24rpx;
  color: #999;
}

.session-score {
  display: flex;
  align-items: baseline;
  margin-left: 20rpx;
}

.score-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #409EFF;
}

.score-label {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}
