.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-card {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.wx-login-btn {
  background: #07C160;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-login-btn .btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.divider-line {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider-line .line {
  flex: 1;
  height: 1rpx;
  background: #e0e0e0;
}

.divider-line text {
  padding: 0 20rpx;
  color: #999;
  font-size: 24rpx;
}

.phone-login .input {
  width: 100%;
  height: 90rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.code-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.code-input {
  flex: 1;
}

.sms-btn {
  width: 200rpx;
  height: 90rpx;
  line-height: 90rpx;
  background: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 0;
}

.sms-btn[disabled] {
  background: #e8e8e8;
  color: #999;
}

.phone-login .btn-primary {
  margin-top: 10rpx;
}
