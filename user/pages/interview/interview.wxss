.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.prepare-section {
  padding: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  display: block;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.input,
.picker.input,
.picker {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker.placeholder {
  color: #999;
}

.difficulty-options {
  display: flex;
  gap: 20rpx;
}

.diff-option {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.diff-option.active {
  border-color: #409EFF;
  color: #409EFF;
  background: #ecf5ff;
}

.resume-select {
  padding: 24rpx;
  border: 2rpx dashed #e8e8e8;
  border-radius: 12rpx;
  text-align: center;
}

.resume-select .placeholder {
  color: #999;
  font-size: 28rpx;
}

.resume-select .selected {
  color: #67C23A;
  font-size: 28rpx;
}

/* 面试进行中 */
.interview-section {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.chat-title {
  font-size: 32rpx;
  font-weight: bold;
}

.chat-area {
  flex: 1;
  padding: 20rpx 30rpx;
}

.message-list {
  padding-bottom: 20rpx;
}

.msg-item {
  display: flex;
  margin-bottom: 24rpx;
}

.msg-item.assistant {
  flex-direction: row;
}

.msg-item.user {
  flex-direction: row-reverse;
}

.msg-avatar {
  font-size: 48rpx;
  margin: 0 16rpx;
}

.msg-content {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.msg-item.assistant .msg-content {
  background: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
}

.msg-item.user .msg-content {
  background: #409EFF;
  color: #fff;
  border-top-right-radius: 4rpx;
}

.typing-indicator {
  display: flex;
  gap: 8rpx;
  padding: 10rpx 0;
}

.typing-indicator .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #999;
  animation: typing 1.4s infinite;
}

.typing-indicator .dot:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-10rpx); opacity: 1; }
}

.input-area {
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  gap: 16rpx;
  align-items: flex-end;
}

.answer-input {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.send-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #409EFF;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 0;
  text-align: center;
}

.send-btn[disabled] {
  background: #a0cfff;
}

.end-btn-area {
  padding: 10rpx 30rpx 30rpx;
  background: #fff;
}

.end-btn-area .btn-secondary {
  font-size: 28rpx;
  padding: 20rpx 0;
}
