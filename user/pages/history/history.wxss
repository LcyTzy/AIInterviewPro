.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.filter-bar {
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-item.active {
  color: #409EFF;
  background: #ecf5ff;
}

.list-container {
  padding: 0 30rpx;
}

.session-card {
  margin-bottom: 20rpx;
}

.session-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.session-position {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.session-body {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
  margin-bottom: 16rpx;
}

.session-info {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.session-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.score-label {
  font-size: 26rpx;
  color: #666;
}

.score-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #409EFF;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
}
