/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 30rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: #409EFF;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
}

.btn-primary:active {
  background: #3a8ee6;
}

.btn-secondary {
  background: #fff;
  color: #409EFF;
  border: 2rpx solid #409EFF;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-blue {
  background: #ecf5ff;
  color: #409EFF;
}

.tag-green {
  background: #f0f9eb;
  color: #67C23A;
}

.tag-orange {
  background: #fdf6ec;
  color: #E6A23C;
}

.tag-red {
  background: #fef0f0;
  color: #F56C6C;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 20rpx 0;
}
